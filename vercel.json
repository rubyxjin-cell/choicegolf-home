{
  "rewrites": [
    { "source": "/og/:t", "destination": "/api/og?t=:t" },
    {
      "source": "/product.html",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(kakaotalk-scrap|facebookexternalhit|Facebot|Twitterbot|Slackbot|Discordbot|LinkedInBot|TelegramBot|WhatsApp|Daum|NaverBot|Yeti).*"
        }
      ],
      "destination": "/api/c"
    }
  ]
}
